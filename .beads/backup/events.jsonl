{"actor":"Ryan Snodgrass","comment":null,"created_at":"2026-03-06T10:08:27Z","event_type":"status_changed","id":121,"issue_id":"ox-f9f","new_value":"{\"status\":\"in_progress\"}","old_value":"{\"id\":\"ox-f9f\",\"title\":\"Implement ox memory import --type=claude\",\"description\":\"Import Claude's per-project memory directory into the ledger at data/claude/memory/{user_id}/. Includes: Claude memory path resolution, sparse checkout expansion/restore, rsync semantics, pushLedger. Data collection only — write-only sink.\",\"status\":\"open\",\"priority\":1,\"issue_type\":\"feature\",\"owner\":\"ryan@sageox.ai\",\"created_at\":\"2026-03-06T18:08:24Z\",\"created_by\":\"Ryan Snodgrass\",\"updated_at\":\"2026-03-06T18:08:24Z\"}"}
