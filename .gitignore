sessions/

# Claude plugin cache/install artifacts (not our source)
.claude-plugin/
# But DO track our plugin marketplace and manifest
!/.claude-plugin/
!/claude-plugin/.claude-plugin/

# Benchmark results (append-only, local to each machine)
tests/integration/agents/benchmark/results.jsonl

# Claude Code local settings (user-specific)
.claude/settings.local.json
demo/credentials.sops.yaml
demo/playwright/node_modules/
.team-contexts/

